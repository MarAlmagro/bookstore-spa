{
  "name": "bookstore-spa",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:e2e": "ng serve --configuration e2e",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --coverage",
    "test:watch": "ng test --watch",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:codegen": "playwright codegen",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "serve:ssr": "node dist/bookstore-spa/server/main.js",
    "analyze": "ng build --configuration production --stats-json && npx webpack-bundle-analyzer dist/bookstore-spa/stats.json",
    "lighthouse": "npx lighthouse http://localhost:4200 --only-categories=accessibility",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.1.2",
    "@angular/cdk": "^21.1.2",
    "@angular/common": "^21.1.2",
    "@angular/compiler": "^21.1.2",
    "@angular/core": "^21.1.2",
    "@angular/forms": "^21.1.2",
    "@angular/material": "^21.1.2",
    "@angular/platform-browser": "^21.1.2",
    "@angular/platform-browser-dynamic": "^21.1.2",
    "@angular/router": "^21.1.2",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular-builders/jest": "^21.0.3",
    "@angular-devkit/build-angular": "^21.1.2",
    "@angular/cli": "^21.1.2",
    "@angular/compiler-cli": "^21.1.2",
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.1",
    "@types/jest": "^30.0.0",
    "angular-eslint": "21.2.0",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-preset-angular": "^16.0.0",
    "lint-staged": "^15.3.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.50.1",
    "wait-on": "^9.0.4"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "git add"
    ],
    "*.html": [
      "eslint --fix",
      "git add"
    ]
  }
}
