  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT authentication token. Include in Authorization header as 'Bearer {token}'"
      }
    },
    "schemas": {
      "BookDTO": {
        "type": "object",
        "required": ["isbn", "title", "author", "price", "stock", "category"],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Unique identifier for the book",
            "readOnly": true
          },
          "isbn": {
            "type": "string",
            "minLength": 10,
            "maxLength": 13,
            "description": "International Standard Book Number (ISBN)",
            "example": "9781234567890"
          },
          "title": {
            "type": "string",
            "maxLength": 255,
            "description": "Title of the book",
            "example": "The Great Gatsby"
          },
          "author": {
            "type": "string",
            "maxLength": 255,
            "description": "Author of the book",
            "example": "F. Scott Fitzgerald"
          },
          "description": {
            "type": "string",
            "maxLength": 1000,
            "description": "Detailed description of the book",
            "example": "A classic American novel set in the Jazz Age"
          },
          "price": {
            "type": "number",
            "format": "decimal",
            "minimum": 0.01,
            "description": "Price of the book",
            "example": 12.99
          },
          "stock": {
            "type": "integer",
            "minimum": 0,
            "description": "Current stock quantity available",
            "example": 50
          },
          "category": {
            "type": "string",
            "maxLength": 100,
            "description": "Category or genre of the book",
            "example": "Fiction"
          }
        }
      },
      "OrderDTO": {
        "type": "object",
        "required": ["userId", "items"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the order (MongoDB ObjectId)",
            "readOnly": true,
            "example": "507f1f77bcf86cd799439011"
          },
          "userId": {
            "type": "integer",
            "format": "int64",
            "description": "Identifier of the user who placed the order",
            "example": 1
          },
          "items": {
            "type": "array",
            "minItems": 1,
            "description": "List of items in the order",
            "items": {
              "$ref": "#/components/schemas/OrderItemDTO"
            }
          },
          "totalAmount": {
            "type": "number",
            "format": "decimal",
            "description": "Total amount for the entire order (auto-calculated)",
            "readOnly": true,
            "example": 45.97
          },
          "status": {
            "type": "string",
            "enum": ["PENDING", "CONFIRMED", "SHIPPED", "DELIVERED", "CANCELLED"],
            "description": "Current status of the order",
            "example": "PENDING"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the order was created",
            "readOnly": true,
            "example": "2026-01-05T21:13:00Z"
          }
        }
      },
      "OrderItemDTO": {
        "type": "object",
        "required": ["bookId", "quantity"],
        "properties": {
          "bookId": {
            "type": "integer",
            "format": "int64",
            "description": "Identifier of the book being ordered",
            "example": 1
          },
          "quantity": {
            "type": "integer",
            "minimum": 1,
            "description": "Quantity of books ordered",
            "example": 2
          },
          "price": {
            "type": "number",
            "format": "decimal",
            "description": "Price per unit at the time of order (auto-populated)",
            "readOnly": true,
            "example": 12.99
          },
          "bookTitle": {
            "type": "string",
            "description": "Title of the book (captured at order time, auto-populated)",
            "readOnly": true,
            "example": "The Great Gatsby"
          },
          "bookIsbn": {
            "type": "string",
            "description": "ISBN of the book (captured at order time, auto-populated)",
            "readOnly": true,
            "example": "9781234567890"
          }
        }
      },
      "UserDTO": {
        "type": "object",
        "required": ["email", "firstName", "lastName", "role"],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Unique identifier for the user",
            "readOnly": true,
            "example": 1
          },
          "email": {
            "type": "string",
            "format": "email",
            "maxLength": 255,
            "description": "Email address of the user (must be unique)",
            "example": "user@example.com"
          },
          "firstName": {
            "type": "string",
            "maxLength": 100,
            "description": "First name of the user",
            "example": "John"
          },
          "lastName": {
            "type": "string",
            "maxLength": 100,
            "description": "Last name of the user",
            "example": "Doe"
          },
          "role": {
            "type": "string",
            "enum": ["CUSTOMER", "ADMIN"],
            "description": "Role of the user in the system",
            "example": "CUSTOMER"
          }
        }
      },
      "AuthRequestDTO": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address of the user attempting to authenticate",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "minLength": 6,
            "description": "Password for authentication",
            "example": "password123"
          }
        }
      },
      "AuthResponseDTO": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "JWT access token for authenticating API requests",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "refreshToken": {
            "type": "string",
            "description": "Refresh token for obtaining new access tokens",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "user": {
            "$ref": "#/components/schemas/UserDTO"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the error occurred",
            "example": "2026-01-05T21:13:00"
          },
          "status": {
            "type": "integer",
            "description": "HTTP status code",
            "example": 404
          },
          "error": {
            "type": "string",
            "description": "Short error type description",
            "example": "Not Found"
          },
          "message": {
            "type": "string",
            "description": "Detailed error message explaining what went wrong",
            "example": "Book with ID 999 not found"
          },
          "path": {
            "type": "string",
            "description": "The request path that caused the error",
            "example": "/api/v1/books/999"
          }
        }
      }
    }
  }
}
